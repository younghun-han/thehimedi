# --- 2. C# 에이전트 소스 코드 생성 ---
Write-Host "[2/3] 에이전트 소스 코드 작성 중..." -ForegroundColor Cyan
$cSharpCode = @"
using System;
using System.Runtime.InteropServices;
using System.Net.Http;
using System.Text;
using System.Threading.Tasks;
using System.Threading;

namespace SKBAgent
{
    [StructLayout(LayoutKind.Sequential, Pack = 1), Serializable]
    public struct _EVTMSG
    {
        public int nService;
        public int nEvtType;
        public int nResult;
        [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 32)]
        public string strDn1;
        [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 32)]
        public string strDn2;
        [MarshalAs(UnmanagedType.ByValTStr, SizeConst = 1024)]
        public string strExtInfo;
    }

    class Program
    {
        private const string APP_KEY = "$appKey";
        private const string HOSPITAL_ID = "$hospitalId";
        private const string SUPABASE_URL = "$supabaseUrl";
        private const string SUPABASE_KEY = "$supabaseKey";

        [DllImport("SKB_OpenAPI_IMS.dll", CallingConvention = CallingConvention.StdCall)]
        public static extern int IMS_Init(string strAppKey);

        [DllImport("SKB_OpenAPI_IMS.dll", CallingConvention = CallingConvention.StdCall)]
        public static extern int IMS_GetEvent(ref _EVTMSG stEvtMsg);

        static readonly HttpClient client = new HttpClient();

        static void Main(string[] args)
        {
            Console.WriteLine("========================================");
            Console.WriteLine("[더하이메디] SKB 실시간 감시 에이전트");
            Console.WriteLine("========================================");

            try {
                int init = IMS_Init(APP_KEY);
                if (init != 0) {
                    Console.WriteLine("[오류] 서버 연결 실패: " + init);
                    Console.WriteLine("잠시 후 다시 시도해 주세요.");
                    return;
                }
                Console.WriteLine(">>> SKB 서버 연결 성공!");
            } catch (Exception ex) {
                Console.WriteLine("[오류] DLL 로드 실패: " + ex.Message);
                return;
            }

            _EVTMSG evt = new _EVTMSG();
            Console.WriteLine(">>> 실시간 통화 감시 중... (종료: Ctrl+C)");

            while (true)
            {
                if (IMS_GetEvent(ref evt) == 0) // SUCCESS
                {
                    string callType = "";
                    if (evt.nService == 13) callType = "incoming";
                    else if (evt.nService == 9) callType = "missed";
                    else if (evt.nService == 14) callType = "completed";

                    if (callType != "")
                    {
                        Console.WriteLine(string.Format("[{0}] 전화 감지: {1} ({2})", DateTime.Now.ToString("HH:mm:ss"), evt.strDn1, callType));
                        Task.Run(() => SendToSupabase(callType, evt.strDn1, evt.strDn2)).Wait();
                    }
                }
                Thread.Sleep(200);
            }
        }

        static async Task SendToSupabase(string type, string caller, string receiver)
        {
            try
            {
                var json = string.Format(
                    "{{\"hospital_id\": \"{0}\", \"call_type\": \"{1}\", \"caller_number\": \"{2}\", \"receiver_number\": \"{3}\"}}",
                    HOSPITAL_ID, type, caller, receiver
                );

                var content = new StringContent(json, Encoding.UTF8, "application/json");
                client.DefaultRequestHeaders.Clear();
                client.DefaultRequestHeaders.Add("apikey", SUPABASE_KEY);
                client.DefaultRequestHeaders.Add("Authorization", "Bearer " + SUPABASE_KEY);

                var response = await client.PostAsync(SUPABASE_URL, content);
                if (!response.IsSuccessStatusCode) {
                    Console.WriteLine("서버 전송 실패: " + response.StatusCode);
                }
            }
            catch {}
        }
    }
}
"@
Set-Content -Path $csFileName -Value $cSharpCode -Encoding UTF8

# --- 3. C# 컴파일 및 실행 ---
if (-not (Test-Path $exeFileName)) {
    Write-Host "[3/3] 에이전트 빌드 중..." -ForegroundColor Cyan
    
    # 윈도우 기본 C# 컴파일러 찾기
    $csc = Get-ChildItem -Path "C:\Windows\Microsoft.NET\Framework64" -Filter "csc.exe" -Recurse | Sort-Object LastWriteTime -Descending | Select-Object -First 1 -ExpandProperty FullName
    if (-not $csc) {
        $csc = Get-ChildItem -Path "C:\Windows\Microsoft.NET\Framework" -Filter "csc.exe" -Recurse | Sort-Object LastWriteTime -Descending | Select-Object -First 1 -ExpandProperty FullName
    }

    if ($csc) {
        & $csc /target:exe /out:$exeFileName $csFileName /nologo
        if ($LASTEXITCODE -eq 0) {
            Remove-Item $csFileName
            Write-Host ">>> 빌드 성공!" -ForegroundColor Green
        }
    } else {
        Write-Host "[오류] C# 컴파일러를 찾을 수 없습니다. .NET Framework가 설치되어 있는지 확인해 주세요." -ForegroundColor Red
        exit
    }
}

Write-Host ">>> 에이전트 실행 중..." -ForegroundColor Green
Start-Process $exeFileName
